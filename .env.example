# Copy to .env and fill in. .env is gitignored.

# --- LLM (synthesis) ---
GROQ_API_KEY=
OPENAI_API_KEY=

# Optional model overrides
# BTMCP_GROQ_MODEL=llama-3.3-70b-versatile
# BTMCP_OPENAI_MODEL=gpt-4o-mini
# BTMCP_GROQ_BASE_URL=https://api.groq.com/openai/v1

# --- Embeddings (vector layer) ---
# Uses OPENAI_API_KEY above. text-embedding-3-small / 1536d / cosine by default.
# BTMCP_EMBEDDING_MODEL=text-embedding-3-small
# BTMCP_EMBEDDING_DIM=1536
# BTMCP_EMBEDDING_BATCH_SIZE=100

# --- Auth (HTTP / hosted deployments) ---
# Required in production. Any non-empty value enables the gate. Unset/empty = open (dev mode).
# Gates: POST /api/ask, GET /api/search?semantic=true, MCP tools/call name=ask | name=search w/ use_semantic=true.
# BTMCP_API_PASSWORD=

# --- MCP visibility ---
# BTMCP_EXPOSE_ASK=1  # also list the `ask` tool in MCP tools/list (still needs API password to call)

# --- CORS (HTTP) ---
# Comma-separated origins. Empty = sane localhost defaults.
# CORS_ALLOWED_ORIGINS=https://your-frontend.example,https://*.netlify.app

# --- Rate limits (per remote IP; "<count>/<period>") ---
# Period: second | minute | hour | day. Read at process startup.
# BTMCP_RATE_LIMIT_ASK=10/minute       # POST /api/ask, MCP ask
# BTMCP_RATE_LIMIT_SEARCH=60/minute    # GET /api/search
# BTMCP_RATE_LIMIT_READ=120/minute     # /api/health, /api/chunk, /api/tree
# BTMCP_RATE_LIMIT_MCP=60/minute       # POST /mcp endpoint as a whole

# --- Cron refresh (used by `python -m indexer.refresh`) ---
# Space-separated. Defaults match the current corpus (Titus + Ruth).
# BTMCP_REFRESH_SOURCES=door43 aquifer
# BTMCP_REFRESH_BOOKS=TIT RUT
# BTMCP_REFRESH_LANG=en

# --- Misc ---
# BTMCP_ENV_FILE=/explicit/path/to/.env   # overrides the default search
