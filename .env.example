# Copy to .env and fill in. .env is gitignored.

# --- LLM (synthesis) ---
GROQ_API_KEY=
OPENAI_API_KEY=

# Optional model overrides
# BTMCP_GROQ_MODEL=llama-3.3-70b-versatile
# BTMCP_OPENAI_MODEL=gpt-4o-mini
# BTMCP_GROQ_BASE_URL=https://api.groq.com/openai/v1

# --- Embeddings (vector layer) ---
# Uses OPENAI_API_KEY above. text-embedding-3-small / 1536d / cosine by default.
# BTMCP_EMBEDDING_MODEL=text-embedding-3-small
# BTMCP_EMBEDDING_DIM=1536
# BTMCP_EMBEDDING_BATCH_SIZE=100

# --- Misc ---
# BTMCP_ENV_FILE=/explicit/path/to/.env   # overrides the default search
